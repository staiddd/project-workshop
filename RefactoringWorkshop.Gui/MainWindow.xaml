<Window x:Class="RefactoringWorkshop.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refactoring Workshop — GUI"
        Height="720" Width="960"
        MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Loaded="MainWindow_OnLoaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Лабораторна №1: застосування рефакторингу до C++ коду"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Варіант:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="VariantCombo" Width="320" SelectedIndex="0">
                <ComboBoxItem Tag="RenameVariable" Content="1 — Перейменування змінної"/>
                <ComboBoxItem Tag="ExtractMethod" Content="4 — Виділення методу"/>
                <ComboBoxItem Tag="RenameMethod" Content="8 — Перейменування методу"/>
            </ComboBox>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Вихідний код (C++)" Margin="0,0,0,8">
            <TextBox x:Name="SourceText"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="13"/>
        </GroupBox>

        <GroupBox x:Name="ParamsGroup" Grid.Row="3" Header="Параметри" Margin="0,0,0,8">
            <Grid>
                <StackPanel x:Name="RenameVariablePanel" Visibility="Visible">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Старе ім'я змінної:" VerticalAlignment="Center"/>
                        <TextBox x:Name="OldVarName" Grid.Column="1" FontFamily="Consolas"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Нове ім'я змінної:" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewVarName" Grid.Column="1" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="ExtractMethodPanel" Visibility="Collapsed">
                    <TextBlock Text="Виділений блок (як у вихідному коді):" Margin="0,0,0,4"/>
                    <TextBox x:Name="SelectedBlock"
                             MinHeight="72"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Нова назва методу:" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewMethodNameExtract" Grid.Column="1" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="RenameMethodPanel" Visibility="Collapsed">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Стара назва методу:" VerticalAlignment="Center"/>
                        <TextBox x:Name="OldMethodName" Grid.Column="1" FontFamily="Consolas"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Нова назва методу:" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewMethodNameRename" Grid.Column="1" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <Button Grid.Row="4"
                Content="Застосувати рефакторинг"
                Padding="16,8"
                HorizontalAlignment="Left"
                Click="Apply_OnClick"
                Margin="0,0,0,8"/>

        <GroupBox Grid.Row="5" Header="Результат">
            <TextBox x:Name="OutputText"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="13"/>
        </GroupBox>
    </Grid>
</Window>
